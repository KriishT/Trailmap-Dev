{
  "name": "@trailmap/mcp",
  "version": "0.1.0",
  "description": "MCP server for querying Trailmap architecture graphs from AI coding agents",
  "main": "./dist/index.js",
  "bin": {
    "trailmap-mcp": "./dist/server.js"
  },
  "scripts": {
    "build": "tsup src/index.ts src/server.ts --format esm --dts",
    "dev": "tsx watch src/server.ts",
    "lint": "eslint src/",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.11.0",
    "@trailmap/scanner": "*",
    "express": "^4.21.2",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@trailmap/typescript-config": "*",
    "@types/express": "^5.0.1",
    "@types/node": "^22.0.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.4",
    "typescript": "5.9.2"
  }
}
